---
layout: null
---
[
  {% for page in site.pages %}
    {
      "title"    : "{{ page.title | escape }}",
      "url"      : "{{ site.baseurl }}{{ page.url }}",
      "content"  : {{ page.content | strip_html | strip_newlines | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  {% for doc_version in site.data.doc_versions.versions %}
    {% assign doc_files = site.static_files | where_exp: "file", "file.path contains '/docs/' and file.path contains doc_version and file.path contains '.html'" %}
    {% for file in doc_files %}
      {% capture file_content %}{% include_file file.path %}{% endcapture %}
      ,{
        "title"    : "API Documentation - {{ doc_version }} - {{ file.name | remove: '.html' | replace: '_', ' ' | capitalize }}",
        "url"      : "{{ site.baseurl }}{{ file.path }}",
        "content"  : {{ file_content | strip_html | strip_newlines | jsonify }}
      }
    {% endfor %}
  {% endfor %}
]